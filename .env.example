# =========================================================
#  VARIÁVEIS DE AMBIENTE - ERP Social/CRAS
#  Copie este arquivo para .env e preencha os valores reais.
#  NUNCA comite o arquivo .env no Git!
# =========================================================

# Banco de Dados PostgreSQL
DB_USER=postgres
DB_PASSWORD=SUBSTITUA_POR_SENHA_FORTE_AQUI

# Credenciais do Administrador Inicial
# (Usadas apenas na primeira inicialização, quando o banco está vazio)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=SUBSTITUA_POR_SENHA_FORTE_AQUI

# E-mail (Gmail com Senha de Aplicativo)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=seu-email@gmail.com
SPRING_MAIL_PASSWORD=sua-senha-de-app-de-16-digitos

# CORS - URLs do frontend autorizadas
CORS_ALLOWED_ORIGINS=https://seu-front.vercel.app
